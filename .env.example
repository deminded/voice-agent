# Salute Speech (SberCloud) — STT and TTS
SALUTE_AUTH_KEY=your-salute-auth-key-here
SALUTE_SCOPE=SALUTE_SPEECH_PERS

# Yandex SpeechKit v3 — alternative STT/TTS provider
# Get from Yandex Cloud console: IAM -> Service accounts -> API keys
YANDEX_API_KEY=your-yandex-api-key-here
# Optional: billing folder ID (needed for some quota configurations)
YANDEX_FOLDER_ID=your-yandex-folder-id-here

# Anthropic — LLM
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# LiveKit Cloud
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# Voice agent
# Default STT/TTS provider: salute | yandex (overridable per-client via /livekit/token)
TTS_PROVIDER=salute

# Web access token (leave empty to disable auth in dev)
VOICE_AGENT_ACCESS_TOKEN=

# --- Optional personalisation ----------------------------------------------
# Files mounted into the agent's system prompt at startup. Leave unset
# for a generic prompt, or point at your own CLAUDE.md / memory dir for
# a personalised assistant.
# VOICE_AGENT_IDENTITY_FILE=/path/to/CLAUDE.md
# VOICE_AGENT_MEMORY_DIR=/path/to/memory
# VOICE_AGENT_CORE_MEMORIES=user_profile.md,user_ai_subjectivity.md
# VOICE_AGENT_USER_NAME=Alice

# Path to vault-memory MCP script (optional). When set and the file
# exists, the worker exposes search/save_reflection tools to the agent.
# VAULT_MEMORY_MCP_SCRIPT=/path/to/vault-memory.py

# Where end-of-session reflections are written. Defaults to
# ~/.voice-agent/reflections; point at an Obsidian vault for direct
# integration.
# VOICE_AGENT_REFLECTIONS_DIR=/path/to/vault/Reflections

# Override the synthesis model (default claude-opus-4-7).
# VOICE_SYNTHESIS_MODEL=claude-opus-4-7

# Where the voice-channel-plugin intake listens (CLI mode forwards
# transcripts here). Default 127.0.0.1:8910.
# VOICE_CLI_INTAKE_URL=http://127.0.0.1:8910/utterance

# Web search via Exa MCP — adds an Exa-backed search tool to the agent.
# EXA_API_KEY=
