# Salute Speech (SberCloud) — STT and TTS
SALUTE_AUTH_KEY=your-salute-auth-key-here
SALUTE_SCOPE=SALUTE_SPEECH_PERS

# Yandex SpeechKit v3 — alternative STT/TTS provider
# Get from Yandex Cloud console: IAM -> Service accounts -> API keys
YANDEX_API_KEY=your-yandex-api-key-here
# Optional: billing folder ID (needed for some quota configurations)
YANDEX_FOLDER_ID=your-yandex-folder-id-here

# Anthropic — LLM
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# LiveKit Cloud
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# Voice agent
# Default STT/TTS provider: salute | yandex (overridable per-client via /livekit/token)
TTS_PROVIDER=salute

# Web access token (leave empty to disable auth in dev)
VOICE_AGENT_ACCESS_TOKEN=
