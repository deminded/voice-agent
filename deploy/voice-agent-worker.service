[Unit]
Description=Voice agent LiveKit worker (Claude STT/LLM/TTS pipeline)
After=network.target voice-agent-server.service

# Edit User and paths for your deployment before running deploy/install.sh.
[Service]
User=voice-agent
WorkingDirectory=/opt/voice-agent
ExecStart=/opt/voice-agent/.venv/bin/python -m voice_agent.livekit_agent start
Restart=always
RestartSec=5
EnvironmentFile=/opt/voice-agent/.env
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
